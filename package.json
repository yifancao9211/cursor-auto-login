{
  "name": "cursor-account-manager",
  "version": "3.3.5",
  "private": true,
  "type": "module",
  "description": "Cursor Account Manager - 一键切号、配额查询、批量登录",
  "main": "electron/main.js",
  "scripts": {
    "predev": "node scripts/check-native.js",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^6.2.6",
    "vitest": "^4.1.0",
    "vue": "^3.5.13",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.cursor-account-manager",
    "productName": "Cursor Account Manager",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist-renderer/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/playwright/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "yifancao9211",
      "repo": "cursor-auto-login"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
